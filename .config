# ========== 目标设备 ==========
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
CONFIG_TARGET_ROOTFS_PARTSIZE=100
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# ========== 编译优化 ==========
CONFIG_CCACHE=y
CONFIG_SSTRIP=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
# ========== 无线合规与诊断 ==========
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_tcpdump-mini=y
# ========== LuCI 基础 ==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
# ========== 中文界面 ==========
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
# ========== 网络组件 ==========
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_opkg=y
# ========== 无线驱动 ==========
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_ath11k-firmware-qcn9074=y
# CONFIG_PACKAGE_kmod-ath10k-ct is not set
# ========== USB 支持 ==========
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y
CONFIG_PACKAGE_smartmontools=y
# ========== HomeProxy ==========
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_sing-box=y
# CONFIG_PACKAGE_sing-box-tiny is not set
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_ucode-mod-digest=y
# CONFIG_PACKAGE_sing-box-geosite is not set
# CONFIG_PACKAGE_sing-box-geoip is not set
# ========== 终端与工具 ==========
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_file=y
# ========== 应用插件 ==========
# CONFIG_PACKAGE_luci-app-opkg is not set
CONFIG_PACKAGE_luci-lua-runtime=y
CONFIG_PACKAGE_luci-app-fileassistant=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-app-crontabs=y
CONFIG_PACKAGE_luci-i18n-crontabs-zh-cn=y
# ========== AdGuard Home ==========
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
CONFIG_PACKAGE_adguardhome=y
# ========== SmartDNS ==========
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_smartdns=y
# ========== DDNS 动态域名 ==========
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
# ========== UPnP ==========
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_miniupnpd-nftables=y
# ========== 流量监控 ==========
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y
# ========== Samba 文件共享 ==========
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
CONFIG_PACKAGE_samba4-server=y
# ========== IPv6 支持 ==========
CONFIG_PACKAGE_luci-app-ipv6helper=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
# ========== 硬件随机数 ==========
CONFIG_PACKAGE_kmod-qca-rng=y
# ========== 明确禁用的包 ==========
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-mosdns is not set
# CONFIG_PACKAGE_v2ray-geoip is not set
# CONFIG_PACKAGE_v2ray-geosite is not set
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_hysteria is not set
# CONFIG_PACKAGE_naiveproxy is not set
# CONFIG_PACKAGE_tuic-client is not set
